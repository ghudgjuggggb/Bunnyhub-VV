-- Button creation
local function makeBtn(text, y)
    local btn = Instance.new("TextButton", menu)
    btn.Size = UDim2.new(1,-60,0,30)
    btn.Position = UDim2.new(0,10,0,y)
    btn.BackgroundColor3 = Color3.fromRGB(70,70,70)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.Text = text..": "..Texts[settings.Language].OFF

    local plus = Instance.new("TextButton", menu)
    plus.Size = UDim2.new(0,30,0,30)
    plus.Position = UDim2.new(1,-40,0,y)
    plus.Text = "+"
    plus.BackgroundColor3 = Color3.fromRGB(90,90,90)
    plus.TextColor3 = Color3.new(1,1,1)

    return btn, plus
end

local function toggle(var, btn, label)
    _G[var] = not _G[var]
    btn.Text = label..": "..(_G[var] and Texts[settings.Language].ON or Texts[settings.Language].OFF)
    btn.BackgroundColor3 = _G[var] and Color3.fromRGB(0,170,255) or Color3.fromRGB(70,70,70)
    return _G[var]
end

local function makeQuick(name, toggleFunc)
    local q = Instance.new("TextButton", quickFrame)
    q.Size = UDim2.new(1,-10,0,30)
    q.Position = UDim2.new(0,5,0,#quickFrame:GetChildren()*35)
    q.BackgroundColor3 = Color3.fromRGB(70,70,70)
    q.TextColor3 = Color3.new(1,1,1)
    q.Font = Enum.Font.GothamBold
    q.TextSize = 14
    q.Text = name
    q.MouseButton1Click:Connect(function()
        toggleFunc()
    end)
    return q
end

