speedLabel.TextXAlignment = Enum.TextXAlignment.Left
speedLabel.Text = Texts[settings.Language].Speed..": "..settings.Speed

local sliderBar = Instance.new("Frame", menu)
sliderBar.Size = UDim2.new(1,-20,0,10)
sliderBar.Position = UDim2.new(0,10,0,245)
sliderBar.BackgroundColor3 = Color3.fromRGB(70,70,70)

local sliderFill = Instance.new("Frame", sliderBar)
sliderFill.Size = UDim2.new(settings.Speed/100,0,1,0)
sliderFill.BackgroundColor3 = Color3.fromRGB(0,170,255)

local sliderButton = Instance.new("TextButton", sliderBar)
sliderButton.Size = UDim2.new(0,15,1,0)
sliderButton.Position = UDim2.new(settings.Speed/100,0,0,0)
sliderButton.Text = ""
sliderButton.BackgroundColor3 = Color3.fromRGB(0,120,255)
sliderButton.AutoButtonColor = false

local dragging = false
sliderButton.MouseButton1Down:Connect(function() dragging = true end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local mouseX = UserInputService:GetMouseLocation().X
        local absPos = sliderBar.AbsolutePosition.X
        local absSize = sliderBar.AbsoluteSize.X
        local val = math.clamp((mouseX-absPos)/absSize,0,1)
        settings.Speed = math.floor(val*100)
        sliderFill.Size = UDim2.new(val,0,1,0)
        sliderButton.Position = UDim2.new(val,0,0,0)
        speedLabel.Text = Texts[settings.Language].Speed..": "..settings.Speed
    end
end)

-- Toggles
bunnyBtn.MouseButton1Click:Connect(function() bunnyEnabled = toggle("BunnyHop", bunnyBtn, Texts[settings.Language].BunnyHop) end)
autoBtn.MouseButton1Click:Connect(function() autoJumpEnabled = toggle("AutoJump", autoBtn, Texts[settings.Language].AutoJump) end)
forceBtn.MouseButton1Click:Connect(function() forceSpeedEnabled = toggle("ForceSpeed", forceBtn, Texts[settings.Language].ForceSpeed) end)
invisBtn.MouseButton1Click:Connect(function()
    invisibleEnabled = toggle("Invisible", invisBtn, Texts[settings.Language].Invisible)
    local char = player.Character
    if char then
        for _,v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") and v.Name~="HumanoidRootPart" then
                v.LocalTransparencyModifier = invisibleEnabled and 1 or 0
            elseif v:IsA("Decal") then
                v.Transparency = invisibleEnabled and 1 or 0
            end
        end
    end
end)

-- QuickButtons creation
local quickMap = {}
local function connectPlus(plus, funcName, btnFunc)
    plus.MouseButton1Click:Connect(function()
        if quickMap[funcName] then
            quickMap[funcName]:Destroy()
            quickMap[funcName] = nil
            plus.Text = "+"
        else
            quickMap[funcName] = makeQuick(funcName, btnFunc)
            plus.Text = "-"
        end
    end)
end

connectPlus(bunnyPlus, "BunnyHop", function() bunnyEnabled = toggle("BunnyHop", bunnyBtn, Texts[settings.Language].BunnyHop) end)
connectPlus(autoPlus, "AutoJump", function() autoJumpEnabled = toggle("AutoJump", autoBtn, Texts[settings.Language].AutoJump) end)
connectPlus(forcePlus, "ForceSpeed", function() forceSpeedEnabled = toggle("ForceSpeed", forceBtn, Texts[settings.Language].ForceSpeed) end)
connectPlus(invisPlus, "Invisible", function() invisibleEnabled = toggle("Invisible", invisBtn, Texts[settings.Language].Invisible) end)

-- Main loop (fixed Speed)
RunService.RenderStepped:Connect(function()
    local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")

    if humanoid then
        if not forceSpeedEnabled then
            humanoid.WalkSpeed = settings.Speed
        end

        if bunnyEnabled and humanoid.FloorMaterial ~= Enum.Material.Air then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end

        if autoJumpEnabled then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end

    if hrp then
        if forceSpeedEnabled then
            local bv = hrp:FindFirstChild("BunnyHubForce") or Instance.new("BodyVelocity")
            bv.Name = "BunnyHubForce"
            bv.MaxForce = Vector3.new(1e5,0,1e5)
            bv.Velocity = hrp.CFrame.LookVector * settings.Speed
            bv.Parent = hrp
        else
            if hrp:FindFirstChild("BunnyHubForce") then
                hrp:FindFirstChild("BunnyHubForce"):Destroy()
            end
        end
    end
end)
